# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — for embeddings (not used in simplified version)
OPENAI_API_KEY=sk-...

# Optional — The Companies API (free tier, 500 credits)
# Get from: https://www.thecompaniesapi.com
COMPANIES_API_KEY=
COMPANIES_API_BASE_URL=https://api.thecompaniesapi.com/v2

# Optional — Double the Donation (volunteer/giving programs)
DOUBLE_THE_DONATION_API_KEY=
DOUBLE_THE_DONATION_BASE_URL=https://doublethedonation.com/api/v2

# Paths (defaults are fine)
OUTPUTS_DIR=./outputs
KNOWLEDGE_BASE_DIR=./knowledge_base
SEED_LIST_PATH=./seed/curated_seed_list.json
